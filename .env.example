# ────────────────────────────────────────────────────────────────────────────
# RubyCrawl — environment variables
#
# Copy this file to .env.local and fill in real values. .env.local is
# gitignored and must never be committed. Production values live only in
# the Vercel dashboard.
# ────────────────────────────────────────────────────────────────────────────

# ── Required from day 1 ─────────────────────────────────────────────────────

# Supabase project URL (e.g. https://luznxhpadjblwnkfzjhn.supabase.co).
# Public — exposed to browser code.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon / publishable key. Public.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role / secret key. SERVER ONLY — never send to browser.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI API key (for embeddings + chat). Server only.
OPENAI_API_KEY=

# Firecrawl API key (for crawling). Server only.
FIRECRAWL_API_KEY=

# App origin used for webhook callbacks + magic-link redirects.
# Public.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ── Required from M2 billing-stripe ─────────────────────────────────────────

# Stripe secret key (sk_test_... in dev / sk_live_... in prod).
# Server only.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...). Server only.
STRIPE_WEBHOOK_SECRET=

# Stripe publishable key (pk_test_... / pk_live_...). Public.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=


# ── Required from M8 hardening-launch ───────────────────────────────────────

# Upstash Redis REST URL (replaces the in-memory rate limiter).
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token.
UPSTASH_REDIS_REST_TOKEN=

# Resend API key (transactional email: welcome, trial-ending, quota warning,
# payment-failed).
RESEND_API_KEY=

# Sentry DSN for error reporting.
SENTRY_DSN=


# ── Test-only (used by vitest integration specs) ────────────────────────────

# Local Supabase stack API URL (from `supabase status`).
SUPABASE_TEST_URL=

# Local Supabase publishable key (sb_publishable_...).
SUPABASE_TEST_ANON_KEY=

# Local Supabase secret key (sb_secret_...).
SUPABASE_TEST_SERVICE_ROLE_KEY=
